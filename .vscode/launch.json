    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Attach by Process ID",
            "processId": "${command:PickProcess}",
            "request": "attach",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "Attach to Integrated Browser",
            "request": "attach",
            "type": "editor-browser",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Attach to Integrated Browser",
            "request": "attach",
            "type": "editor-browser",
            "webRoot": "${workspaceFolder}"
        },

        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Iniciar o Chrome em relação a localhost",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}